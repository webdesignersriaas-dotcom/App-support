PORT=3000
NODE_ENV=development

# ERPNext / Frappe (production URL when ready)
ERP_BASE_URL=https://your-erp-site
ERP_API_KEY=
ERP_API_SECRET=
ERP_BEARER_TOKEN=

ERP_TICKET_DOCTYPE=Support Ticket
ERP_MESSAGE_DOCTYPE=Support Ticket Message
ERP_MESSAGE_TICKET_FIELD=ticket

# Mobile app request signing (must match Flutter SUPPORT_APP_ID / SUPPORT_SIGNING_SECRET)
SUPPORT_ENFORCE_REQUEST_SIGNING=true
SUPPORT_APP_ID=
SUPPORT_SIGNING_SECRET=
REQUEST_SIGNATURE_MAX_SKEW_MS=300000
SUPPORT_SERVER_API_KEY=

# Optional
CORS_ALLOWED_ORIGINS=
REQUESTS_PER_WINDOW=120
REQUEST_WINDOW_MS=60000
